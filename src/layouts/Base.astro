---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title?: string;
  description?: string;
  pillar?: string;
}

const {
  title = 'LiveWire',
  description = "What's working. What's not. No thought leadership.",
  pillar,
} = Astro.props;

const fullTitle = title === 'LiveWire' ? 'LiveWire by SparkMode' : `${title} — LiveWire`;

const navItems = [
  { label: 'The 11pm Search', href: '/11pm-search', class: 'pillar-11pm' },
  { label: 'They Get It Too', href: '/they-get-it-too', class: 'pillar-they' },
  { label: 'No Commission',   href: '/no-commission',  class: 'pillar-nocom' },
  { label: 'Set the Room',    href: '/set-the-room',   class: 'pillar-room' },
  { label: 'Add These',       href: '/add-these',      class: 'pillar-add' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />

  <!-- OG -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="/livewire-og.png" />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />

  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />

  <!-- Google Fonts -->
  <!-- Structured data -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "LiveWire",
    "description": "What's working. What's not. No thought leadership.",
    "url": "https://livewire.sparkmode.com",
    "publisher": {
      "@type": "Organization",
      "name": "SparkMode",
      "url": "https://sparkmode.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://livewire.sparkmode.com/livewire-og.png"
      }
    },
    "inLanguage": "en-US"
  })} />

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-DYX550SGKS"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-DYX550SGKS', {
      page_location: window.location.href,
      page_title: document.title
    });

    // ── LiveWire custom events ─────────────────────────────────────────────

    // 1. Pillar view — which content pillar is being read
    const pillarMatch = window.location.pathname.match(
      /^\/(11pm-search|they-get-it-too|no-commission|set-the-room|add-these)/
    );
    if (pillarMatch) {
      gtag('event', 'pillar_view', {
        pillar_name: pillarMatch[1],
        is_article: window.location.pathname.split('/').length > 3
      });
    }

    // 2. Article read — fires when user scrolls past 75% of the page
    if (window.location.pathname.split('/').length > 3) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            gtag('event', 'article_read', {
              article_url: window.location.pathname,
              pillar: pillarMatch ? pillarMatch[1] : 'unknown'
            });
            observer.disconnect();
          }
        });
      }, { threshold: 0.1 });
      window.addEventListener('load', () => {
        const footer = document.querySelector('.try-this-tonight');
        if (footer) observer.observe(footer);
      });
    }

    // 3. SparkMode CTA click — tracks every "Try SparkMode" click
    window.addEventListener('load', () => {
      document.querySelectorAll('a.header-cta').forEach(el => {
        el.addEventListener('click', () => {
          gtag('event', 'sparkmode_cta_click', {
            location: 'header',
            source_pillar: pillarMatch ? pillarMatch[1] : 'homepage'
          });
        });
      });
    });
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@700&family=Outfit:wght@400;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="gradient-bar-top"></div>

  <header class="site-header">
    <div class="container">
      <a href="/" class="header-logo">
        <img src="/livewire-header-solo.png" alt="LiveWire by SparkMode" />
      </a>
      <nav>
        <ul class="header-nav">
          {navItems.map(item => (
            <li>
              <a href={item.href}
                 class={Astro.url.pathname.startsWith(item.href) ? 'active' : ''}>
                {item.label}
              </a>
            </li>
          ))}
          <li>
            <a href="/about"
               class={Astro.url.pathname === '/about' ? 'active' : ''}>
              About
            </a>
          </li>
          <li>
            <a href="https://sparkmode.com" class="header-cta" target="_blank" rel="noopener">
              Try SparkMode
            </a>
          </li>
        </ul>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <span>LiveWire by <a href="https://sparkmode.com" target="_blank" rel="noopener">SparkMode</a>. What's working. What's not. No thought leadership.</span>
      <a href="https://sparkmode.com" target="_blank" rel="noopener">sparkmode.com</a>
    </div>
  </footer>

  <div class="gradient-bar-bottom"></div>
  <Analytics />
</body>
</html>
