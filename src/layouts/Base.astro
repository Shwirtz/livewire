---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title?: string;
  pageTitle?: string;
  description?: string;
  ogImage?: string;  // per-article image path e.g. '/og/henry-winkler.png'
  // Article-specific meta — only passed from [slug].astro
  isArticle?: boolean;
  canonicalURL?: string;
  publishDate?: string;   // ISO string
  modifiedDate?: string;  // ISO string
  section?: string;       // pillar label e.g. "They Get It Too"
  tags?: string[];
}

const {
  title = 'LiveWire',
  pageTitle,
  ogImage,
  description = "What's working. What's not. No thought leadership.",
  isArticle = false,
  canonicalURL,
  publishDate,
  modifiedDate,
  section,
  tags = [],
} = Astro.props;

const isProduction = import.meta.env.PROD && !import.meta.env.PUBLIC_PREVIEW;

const SITE = 'https://livewire.sparkmode.com';
const serpTitle = pageTitle
  ? (pageTitle.includes('LiveWire') ? pageTitle : `${pageTitle} — LiveWire`)
  : (title === 'LiveWire' ? 'LiveWire by SparkMode' : `${title} — LiveWire`);
const fullTitle = title === 'LiveWire' ? 'LiveWire by SparkMode' : `${title} — LiveWire`;
const ogImageURL = ogImage ? `${SITE}${ogImage}` : `${SITE}/livewire-og.png`;
const ogURL = canonicalURL ?? `${SITE}${Astro.url.pathname}`;

const navItems = [
  { label: '11pm Search',     href: '/11pm-search'    },
  { label: 'They Get It Too', href: '/they-get-it-too'},
  { label: 'No Commission',   href: '/no-commission'  },
  { label: 'Set the Room',    href: '/set-the-room'   },
  { label: 'Add These',       href: '/add-these'      },
  { label: 'About',           href: '/about'          },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{serpTitle}</title>
  <meta name="description" content={description} />
  <meta name="robots" content={isProduction ? 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1' : 'noindex, nofollow'} />
  <meta property="og:locale" content="en_US" />
  <link rel="canonical" href={ogURL} />
  <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
  <link rel="alternate" type="application/rss+xml" title="LiveWire by SparkMode" href="/feed.xml" />

  <!-- Open Graph -->
  <meta property="og:site_name" content="LiveWire by SparkMode" />
  <meta property="og:type" content={isArticle ? 'article' : 'website'} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={isArticle ? description : "LiveWire by SparkMode — What's working. What's not. No thought leadership."} />
  <meta property="og:url" content={ogURL} />
  {isArticle && publishDate && <meta property="article:published_time" content={publishDate} />}
  {isArticle && modifiedDate && <meta property="article:modified_time" content={modifiedDate} />}
  {isArticle && section && <meta property="article:section" content={section} />}
  {isArticle && tags.map(tag => <meta property="article:tag" content={tag} />)}

  <!-- Twitter / X Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@GoSparkMode" />
  <meta name="twitter:creator" content="@GoSparkMode" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />
  <meta name="twitter:image:alt" content={isArticle ? description : "LiveWire by SparkMode — What's working. What's not. No thought leadership."} />
  <meta name="author" content="LiveWire Editorial, SparkMode" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png" />
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context":"https://schema.org","@type":"Blog",
    "name":"LiveWire","description":"What's working. What's not. No thought leadership.",
    "url":"https://livewire.sparkmode.com",
    "publisher":{"@type":"Organization","name":"SparkMode","url":"https://sparkmode.com"}
  })} />
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-DYX550SGKS"></script>
  <script is:inline>
    // Suppress analytics on preview/draft builds
    if (window.location.hostname !== 'livewire.sparkmode.com') {
      window.dataLayer = []; function gtag(){} // no-op
    } else {
    window.dataLayer=window.dataLayer||[];
    function gtag(){dataLayer.push(arguments);}
    gtag('js',new Date());
    gtag('config','G-DYX550SGKS',{page_location:window.location.href,page_title:document.title});
    const pillarMatch=window.location.pathname.match(/^\/(11pm-search|they-get-it-too|no-commission|set-the-room|add-these)/);
    if(pillarMatch){gtag('event','pillar_view',{pillar_name:pillarMatch[1],is_article:window.location.pathname.split('/').length>3});}
    if(window.location.pathname.split('/').length>3){
      // Article completed — fires when 80%+ of the TTT block is visible (genuine read signal)
      const obs=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting){gtag('event','article_completed',{article_url:window.location.pathname,pillar:pillarMatch?pillarMatch[1]:'unknown'});obs.disconnect();}});},{threshold:0.8});
      // Scroll depth — 25%, 50%, 75%
      const depths=[25,50,75];const reached=new Set();
      window.addEventListener('scroll',()=>{const pct=Math.round((window.scrollY/(document.body.scrollHeight-window.innerHeight))*100);depths.forEach(d=>{if(pct>=d&&!reached.has(d)){reached.add(d);gtag('event','scroll_depth',{depth:d,article_url:window.location.pathname,pillar:pillarMatch?pillarMatch[1]:'unknown'});}});});
      window.addEventListener('load',()=>{
        const f=document.querySelector('.try-this-tonight');if(f)obs.observe(f);
        // Share button tracking
        document.querySelectorAll('.share-btn').forEach(el=>{el.addEventListener('click',()=>{const platform=el.classList[1]?.replace('share-','');gtag('event','share_click',{platform,article_url:window.location.pathname,pillar:pillarMatch?pillarMatch[1]:'unknown'});});});
      });
    }
    // Outbound link tracking — all external links including SparkMode CTA
    window.addEventListener('load',()=>{
      document.querySelectorAll('a[href^="http"]').forEach(el=>{el.addEventListener('click',()=>{const url=el.getAttribute('href');const isSparkMode=url.includes('sparkmode.com');gtag('event',isSparkMode?'sparkmode_cta_click':'outbound_click',{url,location:window.location.pathname,pillar:pillarMatch?pillarMatch[1]:'homepage'});});});
    });
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@700&family=Outfit:wght@400;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="accent-bar-top"></div>

  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="header-logo">
        <img src="/livewire-wordmark-solo.png" alt="LiveWire" height="36" />
        <span class="header-byline">by <strong>SparkMode</strong></span>
      </a>
      <nav class="site-nav" id="site-nav">
        {navItems.map(item => (
          <a href={item.href}
             class={`nav-link ${Astro.url.pathname.startsWith(item.href) ? 'active' : ''}`}>
            {item.label}
          </a>
        ))}
      </nav>
      <div class="header-right">
        <a href="https://sparkmode.com" class="header-cta" target="_blank" rel="noopener">
          Try SparkMode
        </a>
        <button class="hamburger" id="hamburger" aria-label="Open menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </header>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <div class="mobile-menu-inner">
      {navItems.map(item => (
        <a href={item.href} class="mobile-nav-link">{item.label}</a>
      ))}
      <a href="https://sparkmode.com" class="mobile-cta" target="_blank" rel="noopener">
        Try SparkMode →
      </a>
    </div>
  </div>

  <main class="site-main">
    <div class="container">
      <slot />
    </div>
  </main>

  <footer class="site-footer">
    <div class="container footer-grid">
      <div class="footer-brand">
        <img src="/livewire-wordmark-solo.png" alt="LiveWire" height="32" />
        <p class="footer-byline">by <strong>SparkMode</strong></p>
        <p class="footer-tagline">SparkMode generates personalized stories built around your child's exact interests, so reading and practice feel like the thing they actually want to do.</p>
        <a href="https://sparkmode.com" class="footer-sparkmode" target="_blank" rel="noopener">
          Try the SparkMode app →
        </a>
      </div>
      <div class="footer-links">
        <p class="footer-links-label">Pillars</p>
        <a href="/11pm-search">The 11pm Search</a>
        <a href="/they-get-it-too">They Get It Too</a>
        <a href="/no-commission">No Commission</a>
        <a href="/set-the-room">Set the Room</a>
        <a href="/add-these">Add These</a>
        <a href="/about" style="margin-top:8px;">About</a>
      </div>
      <div class="footer-signup">
        <p class="footer-links-label">Stay in the loop</p>
        <p class="footer-signup-desc">Get new posts from LiveWire.</p>
        <form class="signup-form" id="footer-signup">
          <input type="email" name="email" placeholder="your@email.com" required class="signup-input" autocomplete="email" />
          <button type="submit" class="signup-btn">Join</button>
        </form>
        <p class="signup-msg" id="signup-msg" aria-live="polite"></p>
      </div>
      <div class="footer-links">
        <p class="footer-links-label">Follow</p>
        <a href="https://x.com/GoSparkMode" target="_blank" rel="noopener">X / Twitter</a>
        <a href="https://instagram.com/GoSparkMode" target="_blank" rel="noopener">Instagram</a>
        <a href="https://tiktok.com/@GoSparkMode" target="_blank" rel="noopener">TikTok</a>
        <a href="https://www.threads.net/@GoSparkMode" target="_blank" rel="noopener">Threads</a>
        <a href="https://sparkmode.com" target="_blank" rel="noopener" style="margin-top:8px;color:var(--color-spark);">SparkMode App</a>
      </div>
    </div>
    <div class="container footer-bottom">
      <span>© {new Date().getFullYear()} SparkMode. All rights reserved.</span>
    </div>
  </footer>

  <div class="accent-bar-bottom"></div>
  <Analytics />

  <script is:inline>
    const form = document.getElementById('footer-signup');
    const msg = document.getElementById('signup-msg');
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = form.querySelector('button');
        const email = form.querySelector('input[name="email"]').value;
        btn.disabled = true;
        btn.textContent = '...';
        msg.className = 'signup-msg';
        msg.textContent = '';
        try {
          const res = await fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email }),
          });
          const data = await res.json();
          if (res.ok) {
            msg.className = 'signup-msg success';
            msg.textContent = 'You\'re on the list.';
            form.reset();
          } else {
            msg.className = 'signup-msg error';
            msg.textContent = data.error || 'Something went wrong.';
          }
        } catch {
          msg.className = 'signup-msg error';
          msg.textContent = 'Something went wrong. Try again.';
        } finally {
          btn.disabled = false;
          btn.textContent = 'Join';
        }
      });
    }
  </script>

  <script is:inline>
    // Hamburger menu toggle
    const hamburger = document.getElementById('hamburger');
    const mobileMenu = document.getElementById('mobile-menu');
    hamburger.addEventListener('click', () => {
      const open = mobileMenu.classList.toggle('open');
      hamburger.classList.toggle('open', open);
      hamburger.setAttribute('aria-expanded', open.toString());
      mobileMenu.setAttribute('aria-hidden', (!open).toString());
    });
    // Close on nav link click
    mobileMenu.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        mobileMenu.classList.remove('open');
        hamburger.classList.remove('open');
        hamburger.setAttribute('aria-expanded', 'false');
        mobileMenu.setAttribute('aria-hidden', 'true');
      });
    });
  </script>
</body>
</html>

<style>
  .accent-bar-top { height: 4px; background: linear-gradient(to right, var(--color-indigo), var(--color-electric), var(--color-glow)); }
  .accent-bar-bottom { height: 3px; background: linear-gradient(to right, var(--color-spark), #c87d10); }

  /* ── Header ── */
  .site-header {
    background: rgba(13,13,20,0.97);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(136,136,170,0.12);
    position: sticky; top: 0; z-index: 200;
  }
  .header-inner { display: flex; align-items: center; gap: 20px; height: 64px; }
  .header-logo { flex-shrink: 0; display: flex; flex-direction: column; align-items: flex-start; text-decoration: none; gap: 2px; }
  .header-logo img { height: 36px; width: auto; display: block; }
  .header-byline { font-family: var(--font-body); font-size: 12px; font-weight: 400; color: rgba(250,250,247,0.65); letter-spacing: 0.01em; line-height: 1; }
  .header-byline strong { font-weight: 700; color: var(--color-white); }
  .header-right { display: flex; align-items: center; gap: 12px; flex-shrink: 0; }

  /* Desktop nav */
  .site-nav { display: flex; align-items: center; gap: 2px; flex: 1; overflow: hidden; }
  .nav-link {
    font-size: 12px; font-weight: 600; color: var(--color-muted);
    text-decoration: none; padding: 5px 8px; border-radius: 4px;
    white-space: nowrap; transition: color 0.15s, background 0.15s;
  }
  .nav-link:hover { color: var(--color-white); background: rgba(255,255,255,0.06); }
  .nav-link.active { color: var(--color-spark); }

  .header-cta {
    font-size: 12px; font-weight: 700;
    color: var(--color-bg); background: var(--color-spark);
    padding: 7px 14px; border-radius: 5px;
    text-decoration: none; white-space: nowrap; transition: opacity 0.15s;
  }
  .header-cta:hover { opacity: 0.85; }

  /* Hamburger button */
  .hamburger {
    display: none; flex-direction: column; justify-content: center;
    gap: 5px; width: 36px; height: 36px; padding: 6px;
    background: none; border: none; cursor: pointer;
  }
  .hamburger span {
    display: block; height: 2px; background: var(--color-white);
    border-radius: 2px; transition: transform 0.2s, opacity 0.2s;
  }
  .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile slide-down menu */
  .mobile-menu {
    display: none; position: fixed; top: 68px; left: 0; right: 0;
    background: rgba(13,13,20,0.99); backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(136,136,170,0.15);
    z-index: 199; transform: translateY(-8px); opacity: 0;
    transition: transform 0.2s ease, opacity 0.2s ease;
    pointer-events: none;
  }
  .mobile-menu.open { transform: translateY(0); opacity: 1; pointer-events: all; }
  .mobile-menu-inner { display: flex; flex-direction: column; padding: 16px 24px 24px; gap: 4px; }
  .mobile-nav-link {
    font-size: 16px; font-weight: 600; color: var(--color-muted);
    text-decoration: none; padding: 12px 0;
    border-bottom: 1px solid rgba(136,136,170,0.08);
    transition: color 0.15s;
  }
  .mobile-nav-link:hover { color: var(--color-white); }
  .mobile-cta {
    margin-top: 16px; font-size: 15px; font-weight: 700;
    color: var(--color-spark); text-decoration: none;
  }

  /* Main */
  .site-main { flex: 1; padding: 56px 0 80px; }

  /* ── Footer ── */
  .site-footer { border-top: 1px solid rgba(136,136,170,0.12); padding: 48px 0 24px; }
  .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1.6fr 1fr; gap: 40px; margin-bottom: 40px; }
  .footer-brand img { height: 32px; width: auto; margin-bottom: 8px; display: block; }
  .footer-byline { font-size: 14px; font-weight: 400; color: rgba(250,250,247,0.55); margin-bottom: 12px; }
  .footer-byline strong { font-weight: 700; color: var(--color-white); }
  .footer-tagline { font-size: 13px; color: var(--color-muted); line-height: 1.6; margin-bottom: 16px; }
  .footer-sparkmode { font-size: 13px; font-weight: 700; color: var(--color-spark); text-decoration: none; }
  .footer-sparkmode:hover { opacity: 0.8; }
  .footer-links { display: flex; flex-direction: column; gap: 10px; }
  .footer-links-label { font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(184,184,208,0.7); margin-bottom: 4px; }
  .footer-links a { font-size: 14px; color: var(--color-muted); text-decoration: none; transition: color 0.15s; }
  .footer-links a:hover { color: var(--color-white); }
  .footer-signup { display: flex; flex-direction: column; gap: 8px; }
  .footer-signup-desc { font-size: 13px; color: var(--color-muted); line-height: 1.5; margin: 0; }
  .signup-form { display: flex; gap: 6px; margin-top: 4px; }
  .signup-input { flex: 1; min-width: 0; background: rgba(255,255,255,0.06); border: 1px solid rgba(136,136,170,0.2); border-radius: 5px; padding: 8px 12px; font-size: 13px; color: var(--color-white); outline: none; transition: border-color 0.15s; }
  .signup-input::placeholder { color: rgba(184,184,208,0.5); }
  .signup-input:focus { border-color: rgba(136,136,170,0.5); }
  .signup-btn { background: var(--color-spark); color: var(--color-bg); border: none; border-radius: 5px; padding: 8px 14px; font-size: 13px; font-weight: 700; cursor: pointer; white-space: nowrap; transition: opacity 0.15s; }
  .signup-btn:hover { opacity: 0.85; }
  .signup-btn:disabled { opacity: 0.5; cursor: default; }
  .signup-msg { font-size: 12px; min-height: 16px; margin: 0; }
  .signup-msg.success { color: #00A896; }
  .signup-msg.error { color: #FF6B6B; }
  .footer-bottom { font-size: 12px; color: rgba(184,184,208,0.6); padding-top: 24px; border-top: 1px solid rgba(136,136,170,0.12); }

  /* ── Responsive ── */
  @media (max-width: 860px) {
    .site-nav { display: none; }
    .hamburger { display: flex; }
    .mobile-menu { display: block; }
    .footer-grid { grid-template-columns: 1fr 1fr; }
    .footer-brand { grid-column: 1 / -1; }
  }  @media (max-width: 600px) {
    .site-main { padding: 40px 0 60px; }
    .footer-grid { grid-template-columns: 1fr; gap: 32px; }
    .header-cta { display: none; }
  }
</style>
