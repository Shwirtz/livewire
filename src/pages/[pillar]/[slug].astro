---
import BaseLayout from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const PILLARS = ['11pm-search','they-get-it-too','no-commission','set-the-room','add-these'];
  const isPreview = import.meta.env.PUBLIC_PREVIEW === 'true';
  const allPosts = (await Promise.all(PILLARS.map(p => getCollection(p as any)))).flat();
  return allPosts
    .filter(post => isPreview || !post.data.draft)
    .map(post => ({
    params: { pillar: post.collection, slug: post.slug },
    props: { post },
  }));
}

const PILLAR_META: Record<string, { label: string; color: string }> = {
  '11pm-search':     { label: 'The 11pm Search',  color: '#7B2FFF' },
  'they-get-it-too': { label: 'They Get It Too',  color: '#00D2FF' },
  'no-commission':   { label: 'No Commission',    color: '#F5A623' },
  'set-the-room':    { label: 'Set the Room',     color: '#00A896' },
  'add-these':       { label: 'Add These',        color: '#4F3FFF' },
};

const { post } = Astro.props;
const { Content } = await post.render();
const meta = PILLAR_META[post.data.pillar];
const canonicalURL = `https://livewire.sparkmode.com/${post.data.pillar}/${post.slug}`;

// Reading time
const wordCount = post.body.split(/\s+/).length;
const readingMins = Math.max(1, Math.round(wordCount / 200));

// Next article in same pillar
const allInPillar = (await getCollection(post.data.pillar as any))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.updatedDate.valueOf() - a.data.updatedDate.valueOf());
const currentIndex = allInPillar.findIndex(p => p.slug === post.slug);
const nextPost = allInPillar[currentIndex + 1] ?? null;

// Social share URLs — native, no third-party scripts
const encoded = encodeURIComponent(canonicalURL);
const encodedText = encodeURIComponent(`${post.data.title} from @GoSparkMode`);
const xShareURL = `https://x.com/intent/tweet?text=${encodedText}&url=${encoded}`;
const fbShareURL = `https://www.facebook.com/sharer/sharer.php?u=${encoded}`;
const whatsappText = encodeURIComponent(`${post.data.title} ${canonicalURL}`);
const whatsappURL = `https://wa.me/?text=${whatsappText}`;
const threadsURL = `https://www.threads.net/intent/post?text=${encodedText}%20${encoded}`;

const articleSchema: Record<string, unknown> = {
  "@context": "https://schema.org", "@type": "Article",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": (post.data.publishedDate ?? post.data.updatedDate).toISOString(),
  "dateModified": post.data.updatedDate.toISOString(),
  "url": canonicalURL,
  "image": `https://livewire.sparkmode.com/og/${post.slug}.png`,
  "keywords": (post.data.keywords ?? []).join(', '),
  "author": { "@type": "Person", "name": "LiveWire Editorial", "url": "https://livewire.sparkmode.com/about" },
  "publisher": { "@type": "Organization", "name": "SparkMode", "url": "https://sparkmode.com",
    "logo": { "@type": "ImageObject", "url": "https://livewire.sparkmode.com/livewire-wordmark-solo.png" }
  },
  "isPartOf": { "@type": "Blog", "name": "They Get It Too", "url": `https://livewire.sparkmode.com/${post.data.pillar}` },
  "mainEntityOfPage": canonicalURL,
};
if (post.data.mentions && post.data.mentions.length > 0) {
  articleSchema["mentions"] = post.data.mentions.map((m: { name: string; wikidata?: string }) => ({
    "@type": "Person",
    "name": m.name,
    ...(m.wikidata ? { "sameAs": `https://www.wikidata.org/wiki/${m.wikidata}` } : {}),
  }));
}

const breadcrumbSchema = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "LiveWire", "item": "https://livewire.sparkmode.com" },
    { "@type": "ListItem", "position": 2, "name": meta.label, "item": `https://livewire.sparkmode.com/${post.data.pillar}` },
    { "@type": "ListItem", "position": 3, "name": post.data.title, "item": canonicalURL },
  ]
};
---
<BaseLayout
  title={post.data.title}
  pageTitle={post.data.pageTitle}
  ogImage={`/og/${post.slug}.png`}
  description={post.data.description}
  isArticle={true}
  canonicalURL={canonicalURL}
  publishDate={(post.data.publishedDate ?? post.data.updatedDate).toISOString()}
  modifiedDate={post.data.updatedDate.toISOString()}
  section={meta.label}
  tags={['learning differences', 'parenting', 'dyslexia', 'ADHD']}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />

  <article class="article" style={`--accent: ${meta.color}`}>
    <nav class="breadcrumb">
      <a href="/">LiveWire</a>
      <span>/</span>
      <a href={`/${post.data.pillar}`}>{meta.label}</a>
    </nav>

    <header class="article-header">
      <h1 class="article-title">{post.data.title}</h1>
      <p class="article-desc">{post.data.description}</p>
      <div class="article-byline">
        <time datetime={(post.data.publishedDate ?? post.data.updatedDate).toISOString()}>
          {(post.data.publishedDate ?? post.data.updatedDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        </time>
        <span>by LiveWire Editorial</span>
        <span>{readingMins} min read</span>
      </div>
    </header>

    <div class="article-body">
      <Content />
    </div>

    <footer class="try-this-tonight">
      <p class="ttt-label">Try This Tonight</p>
      <p class="ttt-text">{post.data.tryThisTonightPrompt}</p>
    </footer>

    <p class="editorial-blurb">LiveWire is written for parents in the trenches — by people who know what 11pm searching feels like. Every post is reported, sourced, and written to be actually useful.</p>

    <!-- Social sharing -->
    <div class="share-bar">
      <span class="share-label">Share this</span>
      <a href={xShareURL} class="share-btn share-x" target="_blank" rel="noopener" aria-label="Share on X">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        X
      </a>
      <a href={threadsURL} class="share-btn share-threads" target="_blank" rel="noopener" aria-label="Share on Threads">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.473 12.01v-.017c.027-3.579.877-6.43 2.525-8.482C5.845 1.205 8.6.024 12.18 0h.014c2.746.018 5.1.799 6.998 2.321 1.78 1.43 2.837 3.45 3.012 5.67l.003.04h-3.017l-.002-.033c-.16-1.707-.88-3.045-2.14-3.982-1.193-.89-2.78-1.336-4.717-1.348h-.01c-2.6.017-4.613.793-5.981 2.307-1.376 1.524-2.077 3.831-2.1 6.856v.013c.023 3.023.722 5.332 2.1 6.859 1.368 1.514 3.382 2.289 5.981 2.305h.013c2.117-.014 3.67-.49 4.886-1.498 1.399-1.16 2.122-2.913 2.228-5.354-.916.252-1.9.39-2.9.39-4.05 0-6.962-2.604-6.962-6.166 0-3.576 2.912-6.18 6.962-6.18 1.13 0 2.193.214 3.121.613.013-.243.02-.488.02-.737 0-2.066-.718-3.806-2.076-5.032C16.023.794 14.21.018 12.186 0zm2.77 11.547c0 1.863-1.34 3.003-3.567 3.003-2.236 0-3.571-1.14-3.571-3.003 0-1.867 1.335-3.003 3.571-3.003 2.227 0 3.567 1.136 3.567 3.003z"/></svg>
        Threads
      </a>
      <a href={fbShareURL} class="share-btn share-fb" target="_blank" rel="noopener" aria-label="Share on Facebook">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        Facebook
      </a>
      <a href={whatsappURL} class="share-btn share-wa" target="_blank" rel="noopener" aria-label="Share on WhatsApp">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        WhatsApp
      </a>
    </div>

    {post.data.sources && post.data.sources.length > 0 && (
      <div class="article-sources">
        <span class="sources-label">Sources</span>
        {post.data.sources.map((s, i) => (
          <>
            {i > 0 && <span class="sources-sep"> / </span>}
            <a href={s.url} target="_blank" rel="noopener">{s.label}</a>
          </>
        ))}
      </div>
    )}

    <nav class="article-nav">
      <a href={`/${post.data.pillar}`} class="nav-back">← {meta.label}</a>
      {nextPost ? (
        <a href={`/${post.data.pillar}/${nextPost.slug}`} class="nav-next">
          <span class="nav-next-label">Next up</span>
          <span class="nav-next-title">{nextPost.data.title}</span>
        </a>
      ) : (
        <a href="/" class="nav-home">All of LiveWire</a>
      )}
    </nav>
  </article>
</BaseLayout>

<style>
  .article { max-width: 680px; margin: 0 auto; }
  .breadcrumb { font-size: 13px; color: var(--color-muted); margin-bottom: 28px; }
  .breadcrumb a { color: var(--color-muted); text-decoration: none; transition: color 0.15s; }
  .breadcrumb a:first-child:hover { color: var(--color-white); }
  .breadcrumb a:last-child { color: var(--accent); }
  .breadcrumb span { margin: 0 6px; opacity: 0.3; }
  .article-header { margin-bottom: 32px; border-bottom: 1px solid rgba(136,136,170,0.1); padding-bottom: 28px; }
  .article-title { font-family: var(--font-display); font-size: clamp(28px, 5vw, 46px); font-weight: 700; letter-spacing: 0.03em; line-height: 1.08; color: var(--color-white); margin-bottom: 16px; }
  .article-desc { font-size: 20px; font-weight: 400; line-height: 1.55; color: var(--color-white); opacity: 0.9; margin-bottom: 16px; }
  .article-byline { display: flex; gap: 16px; font-size: 13px; color: rgba(136,136,170,0.4); flex-wrap: wrap; }
  .article-body { font-size: 17px; line-height: 1.85; color: var(--color-body); margin-bottom: 48px; }
  :global(.article-body p) { margin-bottom: 1.6em; }
  :global(.article-body h2) { font-family: var(--font-display); font-size: 30px; font-weight: 700; letter-spacing: 0.05em; color: var(--accent); margin: 48px 0 16px; }
  :global(.article-body a) { color: var(--accent); text-decoration: none; border-bottom: 1px solid rgba(0,210,255,0.25); transition: border-color 0.15s; }
  :global(.article-body a:hover) { border-bottom-color: var(--accent); }
  :global(.article-body strong) { color: var(--color-white); }
  :global(.article-body em) { font-style: italic; }
  :global(.article-body hr) { border: none; border-top: 1px solid rgba(136,136,170,0.15); margin: 48px 0 32px; }
  :global(.article-body blockquote) { border-left: 3px solid var(--accent); padding: 4px 0 4px 24px; margin: 36px 0; color: var(--color-white); opacity: 0.88; font-style: italic; font-size: 20px; line-height: 1.65; }
  :global(.article-body blockquote footer) { margin-top: 10px; font-style: normal; font-size: 13px; color: var(--color-muted); }
  :global(.article-body blockquote footer cite) { font-style: normal; }
  :global(.article-body blockquote:has(h2)) { border-left: none; padding: 24px 28px; background: rgba(136,136,170,0.06); border-radius: 8px; margin: 40px 0; font-size: inherit; }
  :global(.article-body blockquote h2) { font-family: var(--font-display); font-size: clamp(22px,3vw,30px); font-weight: 700; color: var(--color-white); margin: 0; }
  :global(.article-body figure) { margin: 40px 0; border-left: 3px solid var(--accent); padding-left: 0; }
  :global(.article-body figure iframe) { width: 100%; border-radius: 6px; display: block; }
  :global(.article-body figcaption) { font-size: 14px; color: rgba(180,180,200,0.75); margin-top: 10px; font-style: italic; line-height: 1.5; padding-left: 0; }
  /* Legacy embed-block support (non-markdown embeds) */
  :global(.embed-block) { margin: 40px 0; border-left: 3px solid var(--accent); }
  :global(.embed-block iframe) { width: 100%; border-radius: 6px; display: block; }
  :global(.embed-caption) { font-size: 14px; color: rgba(180,180,200,0.75); margin-top: 10px; font-style: italic; line-height: 1.5; }
  .try-this-tonight { background: var(--color-spark); border-radius: 10px; padding: 28px 32px; margin-bottom: 40px; }
  .ttt-label { font-family: var(--font-display); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(13,13,20,0.65); margin-bottom: 10px; }
  .ttt-text { font-size: 17px; line-height: 1.7; color: var(--color-bg); font-weight: 600; }
  .editorial-blurb { font-size: 13px; color: rgba(136,136,170,0.5); line-height: 1.6; margin-bottom: 32px; font-style: italic; }
  .share-bar { display: flex; align-items: center; gap: 8px; margin-bottom: 32px; flex-wrap: wrap; }
  .share-label { font-size: 12px; font-weight: 700; color: var(--color-muted); letter-spacing: 0.08em; text-transform: uppercase; margin-right: 4px; }
  .share-btn { display: inline-flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 600; text-decoration: none; padding: 7px 14px; border-radius: 6px; border: 1px solid rgba(136,136,170,0.2); color: var(--color-muted); background: transparent; transition: color 0.15s, border-color 0.15s, background 0.15s; }
  .share-btn:hover { color: var(--color-white); border-color: rgba(136,136,170,0.4); background: rgba(136,136,170,0.06); }
  .share-fb:hover { color: #1877F2; border-color: #1877F2; }
  .share-wa:hover { color: #25D366; border-color: #25D366; }
  .article-sources { font-size: 13px; color: rgba(136,136,170,0.8); margin-bottom: 32px; display: flex; align-items: baseline; gap: 6px; flex-wrap: wrap; }
  .sources-label { font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; font-size: 11px; color: rgba(136,136,170,0.7); margin-right: 2px; }
  .sources-sep { opacity: 0.5; }
  .article-sources a { color: rgba(136,136,170,0.8); text-decoration: none; border-bottom: 1px solid rgba(136,136,170,0.35); transition: color 0.15s; }
  .article-sources a:hover { color: var(--color-white); }
  .article-nav { display: flex; justify-content: space-between; align-items: flex-start; padding-top: 28px; border-top: 1px solid rgba(136,136,170,0.12); gap: 24px; }
  .nav-back { color: var(--accent); text-decoration: none; font-weight: 700; font-size: 14px; white-space: nowrap; }
  .nav-back:hover { opacity: 0.8; }
  .nav-next { text-decoration: none; text-align: right; max-width: 340px; }
  .nav-next-label { display: block; font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-muted); margin-bottom: 4px; }
  .nav-next-title { display: block; font-family: var(--font-display); font-size: 15px; font-weight: 700; color: var(--color-white); line-height: 1.3; transition: color 0.15s; }
  .nav-next:hover .nav-next-title { color: var(--accent); }
  .nav-home { color: var(--color-muted); text-decoration: none; font-size: 14px; }
  .nav-home:hover { color: var(--color-white); }
</style>