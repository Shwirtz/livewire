---
import BaseLayout from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const PILLARS = ['11pm-search','they-get-it-too','no-commission','set-the-room','add-these'];
  const allPosts = (await Promise.all(PILLARS.map(p => getCollection(p as any)))).flat();
  return allPosts.map(post => ({
    params: { pillar: post.collection, slug: post.slug },
    props: { post },
  }));
}

const PILLAR_META: Record<string, { label: string; color: string }> = {
  '11pm-search':     { label: 'The 11pm Search',  color: '#7B2FFF' },
  'they-get-it-too': { label: 'They Get It Too',  color: '#00D2FF' },
  'no-commission':   { label: 'No Commission',    color: '#F5A623' },
  'set-the-room':    { label: 'Set the Room',     color: '#00A896' },
  'add-these':       { label: 'Add These',        color: '#4F3FFF' },
};

const { post } = Astro.props;
const { Content } = await post.render();
const meta = PILLAR_META[post.data.pillar];
const canonicalURL = `https://livewire.sparkmode.com/${post.data.pillar}/${post.slug}`;

// Reading time estimate
const wordCount = post.body.split(/\s+/).length;
const readingMins = Math.max(1, Math.round(wordCount / 200));

// Next article in same pillar
const allInPillar = (await getCollection(post.data.pillar as any))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const currentIndex = allInPillar.findIndex(p => p.slug === post.slug);
const nextPost = allInPillar[currentIndex + 1] ?? null;

const articleSchema = {
  "@context": "https://schema.org", "@type": "Article",
  "headline": post.data.title, "description": post.data.description,
  "datePublished": post.data.date.toISOString(), "url": canonicalURL,
  "author": { "@type": "Organization", "name": post.data.author, "url": "https://sparkmode.com" },
  "publisher": { "@type": "Organization", "name": "SparkMode", "url": "https://sparkmode.com" },
  "mainEntityOfPage": canonicalURL,
};
---
<BaseLayout title={post.data.title} description={post.data.description}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(articleSchema)} />
  <link rel="canonical" href={canonicalURL} />

  <article class="article" style={`--accent: ${meta.color}`}>
    <nav class="breadcrumb">
      <a href="/">LiveWire</a>
      <span>/</span>
      <a href={`/${post.data.pillar}`}>{meta.label}</a>
    </nav>

    <header class="article-header">
      <h1 class="article-title">{post.data.title}</h1>
      <p class="article-desc">{post.data.description}</p>
      <div class="article-byline">
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        </time>
        <span>by {post.data.author}</span>
        <span>{readingMins} min read</span>
      </div>
    </header>

    <div class="article-body">
      <Content />
    </div>

    <footer class="try-this-tonight">
      <p class="ttt-label">Try This Tonight</p>
      <p class="ttt-text">{post.data.tryThisTonightPrompt}</p>
    </footer>

    <nav class="article-nav">
      <a href={`/${post.data.pillar}`} class="nav-back">← {meta.label}</a>
      {nextPost ? (
        <a href={`/${post.data.pillar}/${nextPost.slug}`} class="nav-next">
          <span class="nav-next-label">Next up</span>
          <span class="nav-next-title">{nextPost.data.title}</span>
        </a>
      ) : (
        <a href="/" class="nav-home">All of LiveWire</a>
      )}
    </nav>
  </article>
</BaseLayout>

<style>
  .article { max-width: 640px; }

  /* Breadcrumb — LiveWire links home */
  .breadcrumb { font-size: 13px; color: var(--color-muted); margin-bottom: 28px; }
  .breadcrumb a { color: var(--color-muted); text-decoration: none; transition: color 0.15s; }
  .breadcrumb a:first-child:hover { color: var(--color-white); }
  .breadcrumb a:last-child { color: var(--accent); }
  .breadcrumb a:last-child:hover { opacity: 0.8; }
  .breadcrumb span { margin: 0 6px; opacity: 0.3; }

  /* Header */
  .article-header { margin-bottom: 40px; border-bottom: 1px solid rgba(136,136,170,0.1); padding-bottom: 32px; }
  .article-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 5vw, 46px); font-weight: 700;
    letter-spacing: 0.03em; line-height: 1.08;
    color: var(--color-white); margin-bottom: 16px;
  }
  .article-desc { font-size: 18px; line-height: 1.6; color: var(--color-muted); margin-bottom: 16px; }
  .article-byline { display: flex; gap: 16px; font-size: 13px; color: rgba(136,136,170,0.4); }

  /* Body prose */
  .article-body { font-size: 17px; line-height: 1.85; color: var(--color-body); margin-bottom: 48px; }
  .article-body h2 {
    font-family: var(--font-display); font-size: 21px; font-weight: 700;
    letter-spacing: 0.05em; color: var(--accent);
    margin: 48px 0 16px;
  }
  .article-body p { margin-bottom: 24px; }
  .article-body a { color: var(--accent); }
  .article-body strong { color: var(--color-white); }
  .article-body em { font-style: italic; }
  .article-body blockquote {
    border-left: 3px solid var(--accent); padding-left: 20px;
    margin: 32px 0; color: var(--color-muted); font-style: italic;
  }
  /* Pull quote — use > ## text in markdown for a big callout */
  .article-body blockquote h2 {
    font-family: var(--font-display); font-size: clamp(22px, 3vw, 30px);
    font-weight: 700; letter-spacing: 0.04em; line-height: 1.2;
    color: var(--color-white); margin: 0; border: none;
  }
  .article-body blockquote:has(h2) {
    border-left: none; padding: 24px 28px;
    background: rgba(136,136,170,0.06);
    border-radius: 8px; margin: 40px 0;
  }

  /* Try This Tonight — high contrast signature element */
  .try-this-tonight {
    background: var(--color-spark);
    border-radius: 10px; padding: 28px 32px; margin-bottom: 48px;
  }
  .ttt-label {
    font-family: var(--font-display); font-size: 11px; letter-spacing: 0.18em;
    text-transform: uppercase; color: rgba(13,13,20,0.65); margin-bottom: 10px;
  }
  .ttt-text { font-size: 17px; line-height: 1.7; color: var(--color-bg); font-weight: 600; }

  /* Nav */
  .article-nav {
    display: flex; justify-content: space-between; align-items: flex-start;
    padding-top: 28px; border-top: 1px solid rgba(136,136,170,0.12);
    gap: 24px;
  }
  .nav-back { color: var(--accent); text-decoration: none; font-weight: 700; font-size: 14px; white-space: nowrap; }
  .nav-back:hover { opacity: 0.8; }
  .nav-next { text-decoration: none; text-align: right; max-width: 340px; }
  .nav-next-label { display: block; font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-muted); margin-bottom: 4px; }
  .nav-next-title { display: block; font-family: var(--font-display); font-size: 15px; font-weight: 700; color: var(--color-white); line-height: 1.3; transition: color 0.15s; }
  .nav-next:hover .nav-next-title { color: var(--accent); }
  .nav-home { color: var(--color-muted); text-decoration: none; font-size: 14px; }
  .nav-home:hover { color: var(--color-white); }
</style>
