---
import BaseLayout from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const PILLARS = ['11pm-search','they-get-it-too','no-commission','set-the-room','add-these'];
  return PILLARS.map(p => ({ params: { pillar: p } }));
}

const PILLAR_META: Record<string, { label: string; color: string; description: string; manifesto: string }> = {
  '11pm-search':     { label: 'The 11pm Search',  color: '#7B2FFF', description: 'Researched answers to what parents actually Google at night. Specific, cited, no filler.', manifesto: 'Every post in this pillar starts with a real search query. Not a content strategy. Something a parent actually typed, alone, late.' },
  'they-get-it-too': { label: 'They Get It Too',  color: '#00D2FF', description: 'How well-known people describe learning differently, in their own words. No labels.', manifesto: 'We let them say it themselves. No diagnosis applied. No narrative imposed. Just what they said and why it still matters.' },
  'no-commission':   { label: 'No Commission',    color: '#F5A623', description: 'Product recs with zero affiliate codes. We make $0.00 from any link on this site.', manifesto: 'The disclaimer is the whole point. When we say a thing works, we have nothing to gain from saying it.' },
  'set-the-room':    { label: 'Set the Room',     color: '#00A896', description: 'Playlists and ambient audio mapped to specific parenting moments. Not just "focus music."', manifesto: 'The ten minutes before homework matters as much as the homework. Sound changes rooms. Here\'s how we use it.' },
  'add-these':       { label: 'Add These',        color: '#4F3FFF', description: 'Five people worth your feed this week. Short, opinionated, no fluff.', manifesto: 'No courses in the bio. No frameworks to sell. Just people putting out real signal in a space full of noise.' },
};

const { pillar } = Astro.params;
const meta = PILLAR_META[pillar];

const posts = (await getCollection(pillar as any))
  .filter(p => !p.data.draft)
  .sort((a, b) => (b.data.publishedDate ?? b.data.updatedDate).valueOf() - (a.data.publishedDate ?? a.data.updatedDate).valueOf());
---
<BaseLayout title={meta.label} description={meta.description}>
  <div class="pillar-header" style={`--accent: ${meta.color}`}>
    <a href="/" class="back-link">← LiveWire</a>
    <h1 class="pillar-title">{meta.label}</h1>
    <p class="pillar-desc">{meta.description}</p>
    <p class="pillar-manifesto">{meta.manifesto}</p>
  </div>

  {posts.length > 0 ? (
    <section class="feed">
      {posts.map(post => (
        <a href={`/${pillar}/${post.slug}`} class="post-card" style={`--accent: ${meta.color}`}>
          <h2 class="post-title">{post.data.title}</h2>
          <p class="post-desc">{post.data.description}</p>
          <span class="post-meta">
            <time datetime={(post.data.publishedDate ?? post.data.updatedDate).toISOString()}>
              {(post.data.publishedDate ?? post.data.updatedDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
            </time>
            <span class="post-read">Read →</span>
          </span>
        </a>
      ))}
    </section>
  ) : (
    <p class="empty">First post in this pillar coming soon.</p>
  )}
</BaseLayout>

<style>
  .pillar-header { margin-bottom: 40px; padding-bottom: 32px; border-bottom: 1px solid rgba(136,136,170,0.1); }
  .back-link { display: inline-block; font-size: 13px; color: var(--color-muted); text-decoration: none; margin-bottom: 20px; transition: color 0.15s; }
  .back-link:hover { color: var(--color-white); }
  .pillar-title { font-family: var(--font-display); font-size: clamp(32px, 5vw, 56px); font-weight: 700; letter-spacing: 0.04em; color: var(--accent); margin-bottom: 12px; }
  .pillar-desc { font-size: 16px; color: var(--color-muted); line-height: 1.65; max-width: 520px; margin-bottom: 16px; }
  .pillar-manifesto { font-size: 15px; color: rgba(136,136,170,0.6); line-height: 1.65; max-width: 520px; font-style: italic; }

  .post-card {
    display: block; padding: 36px 0; max-width: 720px;
    border-bottom: 1px solid rgba(136,136,170,0.1);
    text-decoration: none; transition: opacity 0.12s;
  }
  .post-card:hover { opacity: 0.85; }
  .post-title { font-family: var(--font-display); font-size: clamp(20px, 3vw, 28px); font-weight: 700; letter-spacing: 0.03em; color: var(--color-white); margin-bottom: 10px; line-height: 1.1; }
  .post-desc { font-size: 15px; line-height: 1.6; color: var(--color-muted); margin-bottom: 14px; }
  .post-meta { display: flex; justify-content: space-between; font-size: 12px; color: rgba(136,136,170,0.5); }
  .post-read { color: var(--accent); font-weight: 700; font-size: 13px; }
  .empty { padding: 60px 0; font-size: 17px; color: var(--color-muted); font-style: italic; }
</style>
