---
import BaseLayout from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allPosts = (await Promise.all([
  getCollection('11pm-search'),
  getCollection('they-get-it-too'),
  getCollection('no-commission'),
  getCollection('set-the-room'),
  getCollection('add-these'),
])).flat();
const isPreview = import.meta.env.PUBLIC_PREVIEW === 'true';
const filteredPosts = allPosts.filter((p: any) => isPreview || !p.data.draft);
filteredPosts.sort((a: any, b: any) => (b.data.publishedDate ?? b.data.updatedDate).valueOf() - (a.data.publishedDate ?? a.data.updatedDate).valueOf());
const recentPosts = filteredPosts.slice(0, 10);
const hasMore = filteredPosts.length > 10;

const PILLAR_META: Record<string, { label: string; color: string; day: string }> = {
  '11pm-search':     { label: 'The 11pm Search',  color: '#7B2FFF', day: 'Mon & Wed' },
  'they-get-it-too': { label: 'They Get It Too',  color: '#00D2FF', day: 'Tuesday'   },
  'no-commission':   { label: 'No Commission',    color: '#F5A623', day: 'Thursday'  },
  'set-the-room':    { label: 'Set the Room',     color: '#00A896', day: 'Friday'    },
  'add-these':       { label: 'Add These',        color: '#4F3FFF', day: 'Rotating'  },
};
---
<BaseLayout>
  <section class="hero">
    <p class="hero-eyebrow">From the SparkMode team</p>
    <h1 class="hero-headline">Real talk for parents<br />who've tried everything.</h1>
    <p class="hero-sub">No frameworks. No signature methods. No book coming out in spring. Just what's actually working, what isn't, and why.</p>
  </section>

  <section class="pillars-grid">
    {Object.entries(PILLAR_META).map(([slug, meta]) => (
      <a href={`/${slug}`} class="pillar-card" style={`--accent: ${meta.color}`}>
        <span class="pillar-name">{meta.label}</span>
        <span class="pillar-day">{meta.day}</span>
      </a>
    ))}
  </section>

  {filteredPosts.length > 0 ? (
    <section class="feed">
      <h2 class="feed-label">Latest</h2>
      {recentPosts.map((post: any) => {
        const meta = PILLAR_META[post.data.pillar];
        const url = `/${post.data.pillar}/${post.slug}`;
        return (
          <a href={url} class="post-card">
            <span class="post-pillar-tag" style={`color: ${meta.color}`}>{meta.label}</span>
            <h2 class="post-title">{post.data.title}</h2>
            <p class="post-desc">{post.data.description}</p>
            <span class="post-meta">
              <time datetime={(post.data.publishedDate ?? post.data.updatedDate).toISOString()}>
                {(post.data.publishedDate ?? post.data.updatedDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
              </time>
              <span class="post-read">Read →</span>
            </span>
          </a>
        );
      })}
      {hasMore && <a href="/archive" class="see-all">See all posts →</a>}
    </section>
  ) : (
    <p class="coming-soon">First posts dropping soon. Check back Monday.</p>
  )}
</BaseLayout>

<style>
  /* Hero */
  .hero { padding-bottom: 40px; border-bottom: 1px solid rgba(136,136,170,0.1); margin-bottom: 32px; }
  .hero-eyebrow { font-size: 11px; font-weight: 700; color: var(--color-spark); letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 16px; }
  .hero-headline { font-family: var(--font-display); font-size: clamp(40px, 6vw, 72px); font-weight: 700; line-height: 1.02; letter-spacing: 0.03em; color: var(--color-white); margin-bottom: 18px; }
  .hero-sub { font-size: 17px; line-height: 1.65; color: var(--color-muted); max-width: 540px; }

  /* Pillar cards */
  .pillars-grid { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 40px; }
  .pillar-card {
    flex: 1; min-width: 160px;
    display: flex; flex-direction: column; gap: 4px;
    padding: 14px 18px;
    border: 1.5px solid var(--accent);
    border-radius: 8px;
    text-decoration: none;
    background: transparent;
    transition: background 0.15s;
  }
  .pillar-card:hover { background: color-mix(in srgb, var(--accent) 8%, transparent); }
  .pillar-name { font-size: 13px; font-weight: 700; color: var(--accent); }
  .pillar-day { font-size: 11px; color: var(--color-muted); }

  /* Feed */
  .feed-label {
    font-family: var(--font-display);
    font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--color-muted); margin-bottom: 4px;
  }

  /* Post cards — entire card is the link */
  .post-card {
    display: block;
    padding: 36px 0;
    border-bottom: 1px solid rgba(136,136,170,0.1);
    text-decoration: none;
    max-width: 720px;
    transition: opacity 0.12s;
  }
  .post-card:hover { opacity: 0.85; }
  .post-pillar-tag {
    display: inline-block;
    font-size: 12px; font-weight: 700; letter-spacing: 0.10em; text-transform: uppercase;
    margin-bottom: 10px;
  }
  .post-title {
    font-family: var(--font-display);
    font-size: clamp(22px, 3vw, 32px); font-weight: 700;
    letter-spacing: 0.03em; line-height: 1.1;
    color: var(--color-white); margin-bottom: 10px;
  }
  .post-desc { font-size: 15px; line-height: 1.6; color: var(--color-muted); margin-bottom: 14px; }
  .post-meta { display: flex; justify-content: space-between; align-items: center; font-size: 12px; color: var(--color-muted); }
  .post-read { color: var(--color-spark); font-weight: 700; font-size: 13px; }

  .coming-soon { padding: 60px 0; font-size: 17px; color: var(--color-muted); font-style: italic; }
  .see-all { display: inline-block; margin-top: 32px; font-size: 14px; font-weight: 700; color: var(--color-spark); text-decoration: none; }
  .see-all:hover { opacity: 0.8; }

  @media (max-width: 600px) {
    .pillar-card { min-width: calc(50% - 5px); }
  }
</style>
